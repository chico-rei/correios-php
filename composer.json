{
    "name": "chico-rei/correios-php",
    "type": "library",
    "description": "correios-php",
    "keywords": ["Correios Web Service", "Correios API"],
    "homepage": "https://github.com/chico-rei/correios-php",
    "license": "MIT",
    "authors": [{
        "name": "Chico Rei",
        "email": "php@chicorei.com.br"
    }],
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^6.0||^7.0",
        "nesbot/carbon": "^2.0||^3.0",
        "psr/simple-cache": "^2.0||^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "php-coveralls/php-coveralls": "^2.7",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "ChicoRei\\Packages\\Correios\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChicoRei\\Packages\\Correios\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": [
            "@phpunit",
            "@phpcs"
        ],
        "phpunit": "phpunit",
        "phpcs": "phpcs"
    }
}
